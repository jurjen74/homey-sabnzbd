{
  "name": { "en": "SABnzbd" },
  "class": "other",
  "capabilities": [
    "onoff",
    "measure_download_speed",
    "sabnzbd_status",
    "measure_queue_size",
    "measure_queue_count"
  ],
  "capabilitiesOptions": {
    "onoff": {
      "title": { "en": "Downloading" }
    },
    "measure_download_speed": {
      "title": { "en": "Speed" }
    },
    "measure_queue_size": {
      "title": { "en": "Queue" }
    },
    "measure_queue_count": {
      "title": { "en": "Items" }
    }
  },
  "settings": [
    {
      "id": "url",
      "type": "text",
      "label": { "en": "URL" },
      "hint": { "en": "SABnzbd URL including scheme and port, e.g. http://192.168.1.100:8080" },
      "value": "http://192.168.1.100:8080"
    },
    {
      "id": "apikey",
      "type": "text",
      "label": { "en": "API Key" },
      "value": ""
    },
    {
      "id": "poll_interval",
      "type": "number",
      "label": { "en": "Poll interval (seconds)" },
      "hint": { "en": "How often to fetch queue status. Lower = more responsive but more network traffic." },
      "value": 10,
      "attr": { "min": 5, "max": 300 }
    }
  ],
  "pair": [
    {
      "id": "connect",
      "navigation": { "next": "list_devices" }
    },
    {
      "id": "list_devices",
      "template": "list_devices",
      "navigation": { "next": "add_devices" }
    },
    {
      "id": "add_devices",
      "template": "add_devices"
    }
  ]
}
