        },
        "measure_queue_count": {
          "title": {
            "en": "Items",
            "nl": "Items"
          }
        }
      },
      "settings": [
        {
          "id": "url",
          "type": "text",
          "label": {
            "en": "URL",
            "nl": "URL"
          },
          "hint": {
            "en": "SABnzbd URL including scheme and port, e.g. http://192.168.1.100:8080",
            "nl": "SABnzbd-URL inclusief protocol en poort, bijv. http://192.168.1.100:8080"
          },
          "value": "http://192.168.1.100:8080"
        },
        {
          "id": "apikey",
          "type": "text",
          "label": {
            "en": "API Key",
            "nl": "API-sleutel"
          },
          "value": ""
        },
        {
          "id": "poll_interval",
          "type": "number",
          "label": {
            "en": "Poll interval (seconds)",
            "nl": "Pollinginterval (seconden)"
          },
          "hint": {
            "en": "How often to fetch queue status. Lower = more responsive but more network traffic.",
            "nl": "Hoe vaak de wachtrij wordt opgehaald. Lager = sneller bijgewerkt maar meer netwerkverkeer."
          },
          "value": 10,
          "attr": {
            "min": 5,
            "max": 300
          }
        }
      ],
      "pair": [
        {
          "id": "connect",
          "navigation": {
            "next": "list_devices"
          }
        },
        {
          "id": "list_devices",
          "template": "list_devices",
          "navigation": {
            "next": "add_devices"
          }
        },
        {
          "id": "add_devices",
          "template": "add_devices"
        }
      ],
      "id": "sabnzbd"
    }
  ],
