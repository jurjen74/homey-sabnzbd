  "flow": {
    "triggers": [
      {
        "title": {
          "en": "A download completed",
          "nl": "Een download is voltooid"
        },
        "hint": {
          "en": "Triggers when a download finishes successfully.",
          "nl": "Activeert wanneer een download succesvol is afgerond."
        },
        "tokens": [
          {
            "name": "name",
            "type": "string",
            "title": {
              "en": "Name",
              "nl": "Naam"
            },
            "example": {
              "en": "Ubuntu 24.04",
              "nl": "Ubuntu 24.04"
            }
          }
        ],
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=sabnzbd"
          }
        ],
        "id": "download_complete"
      },
      {
        "title": {
          "en": "Queue became empty",
          "nl": "Wachtrij is leeggelopen"
        },
        "hint": {
          "en": "Triggers when all downloads complete and the queue is empty.",
          "nl": "Activeert wanneer alle downloads zijn voltooid en de wachtrij leeg is."
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=sabnzbd"
          }
        ],
        "id": "queue_empty"
      },
      {
        "title": {
          "en": "Status changed",
          "nl": "Status gewijzigd"
        },
        "hint": {
          "en": "Triggers whenever the SABnzbd status changes (idle, downloading, paused, error).",
          "nl": "Activeert wanneer de SABnzbd-status wijzigt (inactief, downloaden, gepauzeerd, fout)."
        },
        "tokens": [
          {
            "name": "status",
            "type": "string",
            "title": {
              "en": "Status",
              "nl": "Status"
            },
            "example": {
              "en": "downloading",
              "nl": "downloaden"
            }
          }
        ],
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=sabnzbd"
          }
        ],
        "id": "status_changed"
      }
    ],
    "conditions": [
      {
        "title": {
          "en": "!{{Is|Is not}} actively downloading",
          "nl": "!{{Is|Is niet}} actief aan het downloaden"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=sabnzbd"
          }
        ],
        "id": "is_downloading"
      },
      {
        "title": {
          "en": "Queue !{{is|is not}} paused",
          "nl": "Wachtrij is !{{gepauzeerd|niet gepauzeerd}}"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=sabnzbd"
          }
        ],
        "id": "is_paused"
      },
      {
        "title": {
          "en": "Queue size !{{is|is not}} above {{size}} GB",
          "nl": "Wachtrijgrootte !{{is|is niet}} groter dan {{size}} GB"
        },
        "titleFormatted": {
          "en": "Queue size !{{is|is not}} above [[size]] GB",
          "nl": "Wachtrijgrootte !{{is|is niet}} groter dan [[size]] GB"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=sabnzbd"
          },
          {
            "name": "size",
            "type": "number",
            "title": {
              "en": "Size (GB)",
              "nl": "Grootte (GB)"
            },
            "min": 0,
            "step": 0.1
          }
        ],
        "id": "queue_size_above"
      },
      {
        "title": {
          "en": "Download speed !{{is|is not}} above {{speed}} MB/s",
          "nl": "Downloadsnelheid !{{is|is niet}} hoger dan {{speed}} MB/s"
        },
        "titleFormatted": {
          "en": "Download speed !{{is|is not}} above [[speed]] MB/s",
          "nl": "Downloadsnelheid !{{is|is niet}} hoger dan [[speed]] MB/s"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=sabnzbd"
          },
          {
            "name": "speed",
            "type": "number",
            "title": {
              "en": "Speed (MB/s)",
              "nl": "Snelheid (MB/s)"
            },
            "min": 0,
            "step": 0.5
          }
        ],
        "id": "speed_above"
      },
      {
        "title": {
          "en": "Download speed !{{is|is not}} below {{speed}} MB/s",
          "nl": "Downloadsnelheid !{{is|is niet}} lager dan {{speed}} MB/s"
        },
        "titleFormatted": {
          "en": "Download speed !{{is|is not}} below [[speed]] MB/s",
          "nl": "Downloadsnelheid !{{is|is niet}} lager dan [[speed]] MB/s"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=sabnzbd"
          },
          {
            "name": "speed",
            "type": "number",
            "title": {
              "en": "Speed (MB/s)",
              "nl": "Snelheid (MB/s)"
            },
            "min": 0,
            "step": 0.5
          }
        ],
        "id": "speed_below"
      }
    ],
    "actions": [
      {
        "title": {
          "en": "Add NZB by URL",
          "nl": "NZB toevoegen via URL"
        },
        "titleFormatted": {
          "en": "Add NZB by URL [[url]]",
          "nl": "NZB toevoegen via URL [[url]]"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=sabnzbd"
          },
          {
            "name": "url",
            "type": "text",
            "title": {
              "en": "NZB URL",
              "nl": "NZB-URL"
            },
            "placeholder": {
              "en": "https://...",
              "nl": "https://..."
            }
          }
        ],
        "id": "add_nzb_url"
      },
      {
        "title": {
          "en": "Pause downloading",
          "nl": "Downloaden pauzeren"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=sabnzbd"
          }
        ],
        "id": "pause"
      },
      {
        "title": {
          "en": "Resume downloading",
          "nl": "Downloaden hervatten"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=sabnzbd"
          }
        ],
        "id": "resume"
      },
      {
        "title": {
          "en": "Set speed limit to {{speed}} MB/s",
          "nl": "Snelheidslimiet instellen op {{speed}} MB/s"
        },
        "titleFormatted": {
          "en": "Set speed limit to [[speed]] MB/s",
          "nl": "Snelheidslimiet instellen op [[speed]] MB/s"
        },
        "hint": {
          "en": "Set to 0 for unlimited speed.",
          "nl": "Stel in op 0 voor onbeperkte snelheid."
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=sabnzbd"
          },
          {
            "name": "speed",
            "type": "number",
            "title": {
              "en": "Speed (MB/s, 0 = unlimited)",
              "nl": "Snelheid (MB/s, 0 = onbeperkt)"
            },
            "min": 0,
            "step": 0.5
          }
        ],
        "id": "set_speed_limit"
      }
    ]
  },
  "drivers": [
